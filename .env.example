# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# 기본 URL: jdbc:postgresql://localhost:5432/zoopick
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/zoopick
SPRING_DATASOURCE_USERNAME=your_db_username_here
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# JPA SQL 로그 출력 여부 (기본값: false)
SPRING_JPA_SHOW_SQL=false

# ==========================================
# Mail Configuration (Gmail SMTP)
# ==========================================
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_google_app_password_here

# ==========================================
# Firebase Configuration
# ==========================================
# Firebase 서비스 계정 키 파일 경로 (상대 경로 또는 절대 경로)
FIREBASE_ACCOUNT_KEY_PATH=path/to/firebase-adminsdk.json

# ==========================================
# JWT Configuration
# ==========================================
# JWT 서명용 비밀키 (최소 32자 이상의 랜덤 문자열 권장)
JWT_SECRET=your_super_secret_jwt_key_string_here

# ==========================================
# External Service Configuration
# ==========================================
# AI 서버(FastAPI) 베이스 URL
FASTAPI_BASE_URL=http://localhost:8000
